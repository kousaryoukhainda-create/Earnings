# ===========================================
# SECRETS CONFIGURATION TEMPLATE
# ===========================================
# Copy this file to secrets.properties and fill in your actual values
# DO NOT commit secrets.properties to version control!
# ===========================================

# -------------------------------------------
# AppLovin MAX
# -------------------------------------------
# Get your SDK Key from: https://dash.applovin.com/
appLovinSdkKey=YOUR_APPLOVIN_SDK_KEY_HERE

# -------------------------------------------
# AppsFlyer
# -------------------------------------------
# Get your Dev Key from: https://app.appsflyer.com/
appsFlyerDevKey=YOUR_APPSFLYER_DEV_KEY_HERE

# -------------------------------------------
# Singular
# -------------------------------------------
# Get your App ID and App Key from: https://platform.singular.net/
singularAppId=YOUR_SINGULAR_APP_ID_HERE
singularAppKey=YOUR_SINGULAR_APP_KEY_HERE

# -------------------------------------------
# AdMob Ad Unit IDs (Optional - for testing use test IDs)
# -------------------------------------------
# Interstitial Ad Unit ID
adMobInterstitialAdUnitId=ca-app-pub-394499510306/XXXXXXX
# Banner Ad Unit ID
adMobBannerAdUnitId=ca-app-pub-394499510306/XXXXXXX
# Rewarded Ad Unit ID
adMobRewardedAdUnitId=ca-app-pub-394499510306/XXXXXXX
# Native Ad Unit ID
adMobNativeAdUnitId=ca-app-pub-394499510306/XXXXXXX

# -------------------------------------------
# Fyber FairBid
# -------------------------------------------
# Get your App ID from: https://dashboard.fyber.com/
fyberAppId=YOUR_FYBER_APP_ID_HERE

# -------------------------------------------
# DigitalTurbine
# -------------------------------------------
# Get your API Key from: https://api.digitalturbine.com/
digitalTurbineApiKey=YOUR_DIGITALTURBINE_API_KEY_HERE

# -------------------------------------------
# Huawei HMS (if needed)
# -------------------------------------------
# Get your Client ID from: https://developer.huawei.com/consumer/
huaweiClientId=YOUR_HUAWEI_CLIENT_ID_HERE
